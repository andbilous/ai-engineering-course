# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Default model: дешевий і швидкий, ідеально для демо
MODEL_PRIMARY=openai/gpt-4o-mini
MODEL_FALLBACK_1=anthropic/claude-haiku-4.5
MODEL_FALLBACK_2=google/gemini-2.0-flash-001
MODEL_JUDGE=anthropic/claude-sonnet-4.5

# Langfuse self-hosted (Docker Compose у тій же папці).
# Ці ключі АВТОМАТИЧНО створюються Langfuse при першому запуску `docker compose up -d`
# через LANGFUSE_INIT_* змінні. Жодних кліків у UI не треба.
# Якщо хочеш свої — поміняй і у .env, і у docker-compose.yml одночасно.
LANGFUSE_PUBLIC_KEY=pk-lf-demo-public-key-0000000000000000
LANGFUSE_SECRET_KEY=sk-lf-demo-secret-key-0000000000000000
LANGFUSE_HOST=http://localhost:3000

# Опціонально — логін у UI Langfuse (http://localhost:3000):
#   email:    demo@local.dev
#   password: demo12345
