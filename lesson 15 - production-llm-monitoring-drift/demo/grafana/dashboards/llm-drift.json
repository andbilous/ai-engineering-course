{
  "annotations": {
    "list": [
      {
        "name": "Drift incident",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "enable": true,
        "iconColor": "red",
        "expr": "changes(llm_drift_phase[1m]) > 0",
        "titleFormat": "Drift phase change"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "stat",
      "title": "Drift phase",
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "BASELINE", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "INCIDENT", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "RECOVERED", "color": "blue" } } }
          ],
          "color": { "mode": "fixed", "fixedColor": "white" }
        }
      },
      "targets": [
        { "expr": "llm_drift_phase", "legendFormat": "phase", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Active model version",
      "id": 2,
      "gridPos": { "h": 4, "w": 8, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [
        { "expr": "topk(1, llm_model_version_info)", "legendFormat": "{{model}} @ {{version}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Faithfulness (judge, 1m avg)",
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area"
      },
      "targets": [
        { "expr": "avg(avg_over_time(llm_judge_score[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Refusal rate (1m)",
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area"
      },
      "targets": [
        { "expr": "rate(llm_refusals_total[1m]) / clamp_min(rate(llm_requests_total[1m]), 0.001)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Cost / request (2m, USD)",
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "unit": "currencyUSD", "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.002 },
              { "color": "red", "value": 0.003 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area"
      },
      "targets": [
        { "expr": "rate(llm_cost_usd_total[2m]) / clamp_min(rate(llm_requests_total[2m]), 0.001)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RAGAS judge metrics over time",
      "id": 6,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        { "expr": "avg(avg_over_time(llm_judge_score[30s]))", "legendFormat": "faithfulness", "refId": "A" },
        { "expr": "avg(avg_over_time(llm_judge_relevancy[30s]))", "legendFormat": "answer_relevancy", "refId": "B" },
        { "expr": "avg(avg_over_time(llm_judge_context_precision[30s]))", "legendFormat": "context_precision", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "APM view — p50 / p95 latency (looks healthy during drift)",
      "id": 7,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "drawStyle": "line", "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(llm_request_duration_seconds_bucket[1m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(llm_request_duration_seconds_bucket[1m])))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Refusal rate",
      "id": 8,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line", "spanNulls": true }
        }
      },
      "targets": [
        { "expr": "rate(llm_refusals_total[1m]) / clamp_min(rate(llm_requests_total[1m]), 0.001)", "legendFormat": "refusal_rate", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cost per request",
      "id": 9,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 4,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line", "spanNulls": true }
        }
      },
      "targets": [
        { "expr": "rate(llm_cost_usd_total[2m]) / clamp_min(rate(llm_requests_total[2m]), 0.001)", "legendFormat": "USD / req", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by intent",
      "id": 10,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 20, "drawStyle": "line", "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "targets": [
        { "expr": "sum by (intent) (rate(llm_requests_total[1m]))", "legendFormat": "{{intent}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["llm", "drift", "demo", "lesson-15"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "LLM Production Monitoring — Drift Demo",
  "uid": "llm-drift-demo",
  "version": 1,
  "weekStart": ""
}
