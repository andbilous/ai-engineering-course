# Naive baseline — single stage, full python image, no layer optimization.
# Used only to measure the "before" numbers for the README table.
FROM python:3.11

WORKDIR /app

# COPY everything first, then install — any code change busts the pip cache.
COPY . .

RUN pip install -r app/requirements.txt

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
