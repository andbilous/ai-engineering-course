# Baseline — навмисно "як у 80% туторіалів".
# Повний базовий образ + COPY . . перед pip install.
# Наслідки: ~1.2 GB і повний rebuild pip на будь-яку зміну коду.
FROM python:3.11

WORKDIR /app
COPY . .
RUN pip install -r app/requirements.txt

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
