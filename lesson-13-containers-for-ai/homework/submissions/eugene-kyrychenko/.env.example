# --- required ---
OPENAI_API_KEY=sk-...

# --- models (опційно; дефолти в app/config.py) ---
EMBEDDER_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# --- infra scaffolding ---
# Сервіси оголошені в docker-compose.yml. App наразі їх не використовує
# (config.py має extra="ignore"), але змінні передаються — готово до wiring.
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
